[Unit]
Description=Power Mobile SSH Console
After=network.target

[Service]
Type=simple
WorkingDirectory=/www/wwwroot/power/mobile_ssh_console
Environment=HOST=127.0.0.1
Environment=PORT=6112
ExecStart=/www/wwwroot/power/mobile_ssh_console/venv/bin/python /www/wwwroot/power/mobile_ssh_console/app.py
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
